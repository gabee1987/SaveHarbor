<UserControl x:Class="SaveHarbor.App.Views.Controls.BackupSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SaveHarbor.App.Views.Behaviors"
             xmlns:ui="clr-namespace:SaveHarbor.App.Localization">
    <Border Style="{StaticResource Panel}" Padding="13,11">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="{ui:UiText Backups.Title}" Style="{StaticResource SectionTitle}" />

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource LineSoftBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="9"
                        ToolTip="{ui:UiText Backups.FolderTooltip}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{ui:UiText Backups.Folder}" Style="{StaticResource MicroLabel}" />
                            <TextBlock Text="{Binding BackupRoot}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,3,0,0"
                                       behaviors:CopyOnClick.Text="{Binding BackupRoot}">
                                <TextBlock.ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="{Binding BackupRoot}" />
                                        <TextBlock Text="{ui:UiText Header.ClickToCopy}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="{ui:UiText Backups.Open}"
                                Command="{Binding OpenBackupFolderCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,4"
                                MinWidth="68"
                                MinHeight="30"
                                VerticalAlignment="Center"
                                ToolTip="{ui:UiText Backups.OpenTooltip}" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource LineSoftBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="9"
                        ToolTip="{ui:UiText Backups.LatestTooltip}">
                    <StackPanel>
                        <TextBlock Text="{Binding LatestBackupHeader}"
                                   Style="{StaticResource MutedText}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="11" />
                        <TextBlock Text="{Binding LatestBackupFileName}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,3,0,0"
                                   behaviors:CopyOnClick.Text="{Binding LatestBackupFileName}">
                            <TextBlock.ToolTip>
                                <StackPanel>
                                    <TextBlock Text="{Binding LatestBackupFileName}" />
                                    <TextBlock Text="{ui:UiText Header.ClickToCopy}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                </StackPanel>
                            </TextBlock.ToolTip>
                        </TextBlock>
                        <TextBlock Text="{Binding LatestBackupPath}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource InkBrush}"
                                   Margin="0,4,0,0"
                                   behaviors:CopyOnClick.Text="{Binding LatestBackupPath}">
                            <TextBlock.ToolTip>
                                <StackPanel>
                                    <TextBlock Text="{Binding LatestBackupPath}" />
                                    <TextBlock Text="{ui:UiText Header.ClickToCopy}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                </StackPanel>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource LineSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="9"
                            ToolTip="{ui:UiText Backups.StoredTooltip}">
                        <StackPanel>
                            <TextBlock Text="{ui:UiText Backups.Stored}" Style="{StaticResource MicroLabel}" />
                            <TextBlock Text="{Binding BackupStorageSummary}"
                                       FontWeight="SemiBold"
                                       Margin="0,3,0,0"
                                       behaviors:CopyOnClick.Text="{Binding BackupStorageSummary}">
                                <TextBlock.ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="{Binding BackupStorageSummary}" />
                                        <TextBlock Text="{ui:UiText Header.ClickToCopy}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource LineSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="9"
                            ToolTip="{Binding SafetyHint}">
                        <StackPanel>
                            <TextBlock Text="{ui:UiText Backups.Safety}" Style="{StaticResource MicroLabel}" />
                            <TextBlock Text="{Binding SafetyHint}"
                                       Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
