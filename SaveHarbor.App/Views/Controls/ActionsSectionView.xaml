<UserControl x:Class="SaveHarbor.App.Views.Controls.ActionsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SaveHarbor.App.Views.Behaviors">
    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Actions" Style="{StaticResource SectionTitle}"
                       ToolTip="Commands for local backup/restore/import and cloud synchronization." />

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource LineSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    ToolTip="Local save operations. These work without cloud sync.">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Local files" Style="{StaticResource MicroLabel}" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="Backup"
                                Command="{Binding CreateBackupCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="32"
                                Padding="9,5"
                                ToolTip="Create a zip backup of the selected world. Windrose must be closed." />
                        <Button Grid.Column="2"
                                Content="Restore"
                                Command="{Binding RestoreBackupCommand}"
                                Style="{StaticResource SecondaryButton}"
                                MinHeight="32"
                                Padding="9,5"
                                ToolTip="Replace the selected local world from a SaveHarbor backup. A safety backup is created first." />
                        <Button Grid.Column="4"
                                Content="Import"
                                Command="{Binding ImportBackupCommand}"
                                Style="{StaticResource SecondaryButton}"
                                MinHeight="32"
                                Padding="9,5"
                                ToolTip="Import a SaveHarbor backup as a world on this PC. Useful for a friend receiving the world for the first time." />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource LineSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    ToolTip="Cloud sync state and actions. Google Drive will be added behind this provider-independent sync layer.">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="7" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cloud sync" Style="{StaticResource MicroLabel}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CloudProviderText}"
                                   Style="{StaticResource MutedText}"
                                   ToolTip="{Binding CloudAccountText}" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="Check"
                                Command="{Binding CheckCloudCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#1E2E44"
                                BorderBrush="#36577D"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Check the cloud manifest, latest version, and active session state." />
                        <Button Grid.Column="2"
                                Content="Upload"
                                Command="{Binding UploadCloudCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#1E332D"
                                BorderBrush="#357866"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Upload the selected local world to the cloud provider. Upload is blocked if cloud changed while you played." />
                        <Button Grid.Column="4"
                                Content="Download"
                                Command="{Binding DownloadCloudCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#352A1E"
                                BorderBrush="#8A6634"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Download and restore the latest cloud save. A local backup is created before restore." />
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="Start session"
                                Command="{Binding StartCloudSessionCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#1E2E44"
                                BorderBrush="#36577D"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Mark that you are starting to play from the current cloud version, so friends see an active session warning." />
                        <Button Grid.Column="2"
                                Content="End session"
                                Command="{Binding EndCloudSessionCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#1A2229"
                                BorderBrush="{StaticResource LineBrush}"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Clear your active session lock if you stop playing without uploading." />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
