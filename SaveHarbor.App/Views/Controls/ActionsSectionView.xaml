<UserControl x:Class="SaveHarbor.App.Views.Controls.ActionsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SaveHarbor.App.Views.Behaviors"
             xmlns:ui="clr-namespace:SaveHarbor.App.Localization">
    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{ui:UiText Actions.Title}" Style="{StaticResource SectionTitle}"
                       ToolTip="{ui:UiText Actions.TitleTooltip}" />

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource LineSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    ToolTip="{ui:UiText Actions.LocalFilesTooltip}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{ui:UiText Actions.LocalFiles}" Style="{StaticResource MicroLabel}" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="{ui:UiText Actions.Backup}"
                                Command="{Binding CreateBackupCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="32"
                                Padding="9,5"
                                ToolTip="{ui:UiText Actions.BackupTooltip}" />
                        <Button Grid.Column="2"
                                Content="{ui:UiText Actions.Restore}"
                                Command="{Binding RestoreBackupCommand}"
                                Style="{StaticResource SecondaryButton}"
                                MinHeight="32"
                                Padding="9,5"
                                ToolTip="{ui:UiText Actions.RestoreTooltip}" />
                        <Button Grid.Column="4"
                                Content="{ui:UiText Actions.Import}"
                                Command="{Binding ImportBackupCommand}"
                                Style="{StaticResource SecondaryButton}"
                                MinHeight="32"
                                Padding="9,5"
                                ToolTip="{ui:UiText Actions.ImportTooltip}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource LineSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    ToolTip="{ui:UiText Actions.CloudTooltip}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="7" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{ui:UiText Actions.CloudSync}" Style="{StaticResource MicroLabel}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CloudProviderText}"
                                   Style="{StaticResource MutedText}"
                                   ToolTip="{Binding CloudAccountText}" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="{ui:UiText Actions.Check}"
                                Command="{Binding CheckCloudCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#1E2E44"
                                BorderBrush="#36577D"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="{ui:UiText Actions.CheckTooltip}" />
                        <Button Grid.Column="2"
                                Content="{ui:UiText Actions.Upload}"
                                Command="{Binding UploadCloudCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#1E332D"
                                BorderBrush="#357866"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="{ui:UiText Actions.UploadTooltip}" />
                        <Button Grid.Column="4"
                                Content="{ui:UiText Actions.Download}"
                                Command="{Binding DownloadCloudCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#352A1E"
                                BorderBrush="#8A6634"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="{ui:UiText Actions.DownloadTooltip}" />
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="{ui:UiText Actions.StartSession}"
                                Command="{Binding StartCloudSessionCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#1E2E44"
                                BorderBrush="#36577D"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="{ui:UiText Actions.StartSessionTooltip}" />
                        <Button Grid.Column="2"
                                Content="{ui:UiText Actions.EndSession}"
                                Command="{Binding EndCloudSessionCommand}"
                                MinHeight="30"
                                Padding="8,4"
                                Background="#1A2229"
                                BorderBrush="{StaticResource LineBrush}"
                                Foreground="{StaticResource InkBrush}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="{ui:UiText Actions.EndSessionTooltip}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
