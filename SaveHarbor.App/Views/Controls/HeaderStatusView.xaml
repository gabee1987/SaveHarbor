<UserControl x:Class="SaveHarbor.App.Views.Controls.HeaderStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SaveHarbor.App.Views.Behaviors"
             xmlns:domain="clr-namespace:SaveHarbor.App.Domain"
             xmlns:ui="clr-namespace:SaveHarbor.App.Localization">
    <Grid Margin="20,14,20,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="780" />
        </Grid.ColumnDefinitions>

        <StackPanel ToolTip="{ui:UiText Header.AppTooltip}">
            <TextBlock Text="{ui:UiText App.Title}" FontSize="25" FontWeight="SemiBold" />
            <TextBlock Text="{ui:UiText App.Subtitle}" Style="{StaticResource MutedText}" FontSize="12" Margin="1,2,0,0" />
        </StackPanel>

        <Grid Grid.Column="1"
              HorizontalAlignment="Right"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="105" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="145" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="96" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource HeaderChip}"
                    ToolTip="{ui:UiText Header.StatusTooltip}">
                <StackPanel>
                    <TextBlock Text="{ui:UiText Header.Status}" Style="{StaticResource HeaderChipLabel}" />
                    <TextBlock Text="{Binding StatusText}"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource HeaderChipValue}"
                               behaviors:CopyOnClick.Text="{Binding StatusText}">
                        <TextBlock.ToolTip>
                            <StackPanel>
                                <TextBlock Text="{Binding StatusText}" />
                                <TextBlock Text="{ui:UiText Header.ClickToCopy}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource HeaderChip}">
                <Border.ToolTip>
                    <StackPanel>
                        <TextBlock Text="{Binding CloudDetailText}" />
                        <TextBlock Text="{Binding CloudAccountText}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border.ToolTip>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="8" Height="8" VerticalAlignment="Top" Margin="0,4,0,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource SubtleBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CloudStatus.State}" Value="{x:Static domain:CloudSyncState.UpToDate}">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CloudStatus.State}" Value="{x:Static domain:CloudSyncState.LocalNewerUploadSafe}">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CloudStatus.State}" Value="{x:Static domain:CloudSyncState.CloudNewer}">
                                        <Setter Property="Fill" Value="{StaticResource WarnBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CloudStatus.State}" Value="{x:Static domain:CloudSyncState.SomeonePlaying}">
                                        <Setter Property="Fill" Value="{StaticResource WarnBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CloudStatus.State}" Value="{x:Static domain:CloudSyncState.Conflict}">
                                        <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{ui:UiText Header.Cloud}" Style="{StaticResource HeaderChipLabel}" />
                        <TextBlock Text="{Binding CloudStateText}"
                                   Style="{StaticResource HeaderChipValue}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource HeaderChip}"
                    ToolTip="{ui:UiText Header.LatestTooltip}">
                <StackPanel>
                    <TextBlock Text="{ui:UiText Header.Latest}" Style="{StaticResource HeaderChipLabel}" />
                    <TextBlock Text="{Binding CloudLatestVersionText}"
                               Style="{StaticResource HeaderChipValue}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="6"
                    Style="{StaticResource HeaderChip}"
                    ToolTip="{Binding CloudSessionTooltip}">
                <StackPanel>
                    <TextBlock Text="{ui:UiText Header.Session}" Style="{StaticResource HeaderChipLabel}" />
                    <TextBlock Text="{Binding CloudSessionText}"
                               Style="{StaticResource HeaderChipValue}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="8"
                    Style="{StaticResource HeaderChip}"
                    ToolTip="{ui:UiText Header.GameTooltip}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="8" Height="8" VerticalAlignment="Top" Margin="0,4,0,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource WarnBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{ui:UiText Header.Game}" Style="{StaticResource HeaderChipLabel}" />
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource HeaderChipValue}">
                                    <Setter Property="Text" Value="{ui:UiText Header.GameClosed}" />
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                                            <Setter Property="Text" Value="{ui:UiText Header.GameRunning}" />
                                            <Setter Property="Foreground" Value="{StaticResource WarnBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
