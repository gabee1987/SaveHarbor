<UserControl x:Class="SaveHarbor.App.Views.Controls.WorldSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SaveHarbor.App.Views.Behaviors">
    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="World" Style="{StaticResource SectionTitle}"
                           ToolTip="The selected local Windrose world SaveHarbor will back up, restore, upload, or replace." />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Open folder"
                            Command="{Binding OpenWorldFolderCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,4"
                            MinHeight="30"
                            Margin="0,0,8,0"
                            ToolTip="Open the selected Windrose world save folder." />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,4"
                            MinHeight="30"
                            ToolTip="Scan the Windrose save folder again and refresh world/backup status." />
                </StackPanel>
            </Grid>

            <ComboBox Grid.Row="1"
                      ItemsSource="{Binding Worlds}"
                      SelectedItem="{Binding SelectedWorld}"
                      Margin="0,10,0,0"
                      ToolTip="Choose which detected Windrose world this app should manage." />

            <UniformGrid Grid.Row="2" Columns="5" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Name" Style="{StaticResource MicroLabel}" ToolTip="Display name from WorldDescription.json." />
                    <TextBlock Text="{Binding SelectedWorld.WorldName, TargetNullValue=Not selected}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,8,0"
                               behaviors:CopyOnClick.Text="{Binding SelectedWorld.WorldName}">
                        <TextBlock.ToolTip>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedWorld.WorldName}" />
                                <TextBlock Text="Click to copy" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Preset" Style="{StaticResource MicroLabel}" ToolTip="World preset type from the Windrose world description." />
                    <TextBlock Text="{Binding SelectedWorld.WorldPresetType, TargetNullValue=Unknown}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,8,0"
                               ToolTip="{Binding SelectedWorld.WorldPresetType}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Size" Style="{StaticResource MicroLabel}" ToolTip="Current size of the selected world folder." />
                    <TextBlock Text="{Binding SelectedWorldSize}" FontWeight="SemiBold" Margin="0,3,8,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Files" Style="{StaticResource MicroLabel}" ToolTip="Number of files inside the selected world folder." />
                    <TextBlock Text="{Binding SelectedWorldFileCount}" FontWeight="SemiBold" Margin="0,3,8,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="World ID" Style="{StaticResource MicroLabel}" ToolTip="Internal world id used as the save folder name." />
                    <TextBlock Text="{Binding SelectedWorld.WorldId, TargetNullValue=Unknown}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,0,0"
                               behaviors:CopyOnClick.Text="{Binding SelectedWorld.WorldId}">
                        <TextBlock.ToolTip>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedWorld.WorldId}" />
                                <TextBlock Text="Click to copy" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </UniformGrid>

            <Border Grid.Row="3"
                    Margin="0,12,0,0"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource LineSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="94" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Modified" Style="{StaticResource MicroLabel}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedWorld.LastModifiedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=Unknown}" FontWeight="SemiBold" />
                        <TextBlock Text="  •  " Foreground="{StaticResource SubtleBrush}" />
                        <TextBlock Text="{Binding SelectedWorldModifiedAge}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Local path" Style="{StaticResource MicroLabel}" VerticalAlignment="Top" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding SelectedWorld.SavePath, TargetNullValue=No world selected}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource InkBrush}"
                               VerticalAlignment="Top"
                               behaviors:CopyOnClick.Text="{Binding SelectedWorld.SavePath}">
                        <TextBlock.ToolTip>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedWorld.SavePath}" />
                                <TextBlock Text="Click to copy" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </TextBlock.ToolTip>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
