<Window x:Class="SaveHarbor.App.Views.Dialogs.CloudFolderSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SaveHarbor.App.Localization"
        Title="{ui:UiText CloudSetup.Title}"
        Width="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="{ui:UiText CloudSetup.Title}"
                           FontSize="17"
                           FontWeight="SemiBold" />
                <TextBlock Text="{ui:UiText CloudSetup.Subtitle}"
                           Style="{StaticResource MutedText}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource LineSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="{ui:UiText CloudSetup.FolderLink}"
                               Style="{StaticResource MicroLabel}" />
                    <TextBox x:Name="FolderInput"
                             Margin="0,7,0,0"
                             MinHeight="36"
                             Padding="9,7"
                             Background="{StaticResource InputBrush}"
                             BorderBrush="{StaticResource LineBrush}"
                             Foreground="{StaticResource InkBrush}"
                             CaretBrush="{StaticResource InkBrush}"
                             TextWrapping="NoWrap"
                             ToolTip="{ui:UiText CloudSetup.FolderLinkTooltip}" />
                    <TextBlock Text="{ui:UiText CloudSetup.Help}"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText"
                       Grid.Row="4"
                       Foreground="{StaticResource MutedBrush}"
                       Text="{ui:UiText CloudSetup.Ready}"
                       TextWrapping="Wrap"
                       LineHeight="18" />

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="{ui:UiText CloudSetup.Cancel}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="96"
                        MinHeight="34"
                        Click="CancelButton_Click" />

                <Button x:Name="TestButton"
                        Grid.Column="3"
                        Content="{ui:UiText CloudSetup.Test}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="104"
                        MinHeight="34"
                        Click="TestButton_Click" />

                <Button x:Name="SaveButton"
                        Grid.Column="5"
                        Content="{ui:UiText CloudSetup.Save}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="104"
                        MinHeight="34"
                        IsEnabled="False"
                        Click="SaveButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
