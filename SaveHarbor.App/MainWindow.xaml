<Window x:Class="SaveHarbor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:SaveHarbor.App.Views.Controls"
        xmlns:ui="clr-namespace:SaveHarbor.App.Localization"
        mc:Ignorable="d"
        Title="{ui:UiText App.Title}"
        Height="690"
        Width="1120"
        MinHeight="660"
        MinWidth="1040"
        Background="#0D1114"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:HeaderStatusView />

        <Grid Grid.Row="1" Margin="20,0,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*" MinWidth="400" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1.18*" MinWidth="470" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:WorldSectionView />
                <controls:BackupSectionView Grid.Row="2" />
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <controls:ActionsSectionView />
                <controls:ActivitySectionView Grid.Row="2" />
            </Grid>
        </Grid>

        <controls:ToastHostView Grid.RowSpan="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,20,20" />

        <controls:IndeterminateProgressLineView Grid.RowSpan="2"
                                                VerticalAlignment="Bottom"
                                                IsActive="{Binding IsBusy}" />
    </Grid>
</Window>
