<Window x:Class="SaveHarbor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:domain="clr-namespace:SaveHarbor.App.Domain"
        mc:Ignorable="d"
        Title="SaveHarbor"
        Height="760"
        Width="1360"
        MinHeight="740"
        MinWidth="1020"
        Background="#0D1114"
        FontFamily="Segoe UI"
        FontSize="14"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0D1114" />
        <SolidColorBrush x:Key="PanelBrush" Color="#151B20" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#10161A" />
        <SolidColorBrush x:Key="InputBrush" Color="#0F1519" />
        <SolidColorBrush x:Key="LineBrush" Color="#26313A" />
        <SolidColorBrush x:Key="LineSoftBrush" Color="#1F2931" />
        <SolidColorBrush x:Key="InkBrush" Color="#F3F6F8" />
        <SolidColorBrush x:Key="MutedBrush" Color="#93A1AD" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#65727E" />
        <SolidColorBrush x:Key="AccentBrush" Color="#19A38C" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#22BCA3" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#128873" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF6B66" />
        <SolidColorBrush x:Key="WarnBrush" Color="#FFB454" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#42D392" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MicroLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#06100E" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentPressedBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentPressedBrush}" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.38" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#1A2229" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222C35" />
                    <Setter Property="BorderBrush" Value="#35424D" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#11181D" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.38" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{StaticResource InputBrush}"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  Margin="0,0,10,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Stretch" />
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{StaticResource MutedBrush}"
                                                      Width="8"
                                                      Height="4"
                                                      Stretch="Uniform"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#35424D" />
                                                <Setter TargetName="Chrome" Property="Background" Value="#131B20" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer Margin="0,4"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource LineSoftBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1F2B33" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#17352F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource SubtleBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource LineBrush}" />
        </Style>

        <DataTemplate DataType="{x:Type domain:WindroseWorld}">
            <StackPanel>
                <TextBlock Text="{Binding WorldName}" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                <TextBlock Text="{Binding WorldId}" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,20,28,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="SaveHarbor" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="Windrose world sharing helper" Style="{StaticResource MutedText}" FontSize="13" Margin="1,5,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="13,9"
                    CornerRadius="8"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="9" Height="9" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource WarnBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Game closed" />
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                                        <Setter Property="Text" Value="Game running" />
                                        <Setter Property="Foreground" Value="{StaticResource WarnBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="28,0,28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" MinWidth="430" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1.25*" MinWidth="500" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="World" Style="{StaticResource SectionTitle}" />
                                <Button Grid.Column="1"
                                        Content="Refresh"
                                        Command="{Binding RefreshCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="13,7"
                                        MinHeight="36" />
                            </Grid>

                            <ComboBox ItemsSource="{Binding Worlds}"
                                      SelectedItem="{Binding SelectedWorld}"
                                      Margin="0,12,0,0" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="World name" Style="{StaticResource MicroLabel}" />
                                    <TextBlock Text="{Binding SelectedWorld.WorldName, TargetNullValue=Not selected}" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Preset" Style="{StaticResource MicroLabel}" />
                                    <TextBlock Text="{Binding SelectedWorld.WorldPresetType, TargetNullValue=Unknown}" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Size" Style="{StaticResource MicroLabel}" />
                                    <TextBlock Text="{Binding SelectedWorldSize}" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <TextBlock Text="Files" Style="{StaticResource MicroLabel}" />
                                    <TextBlock Text="{Binding SelectedWorldFileCount}" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>

                            <Border Margin="0,14,0,0"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource LineSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Last modified" Style="{StaticResource MicroLabel}" />
                                    <TextBlock Text="{Binding SelectedWorld.LastModifiedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=Unknown}"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,2" />
                                    <TextBlock Text="{Binding SelectedWorldModifiedAge}" Style="{StaticResource MutedText}" Margin="0,0,0,10" />
                                    <TextBlock Text="Local path" Style="{StaticResource MicroLabel}" />
                                    <TextBlock Text="{Binding SelectedWorld.SavePath, TargetNullValue=No world selected}"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0"
                                               Foreground="{StaticResource InkBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Margin="0,10,0,0" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="Local safety" Style="{StaticResource SectionTitle}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="7" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="7" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="9" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Backups" Style="{StaticResource MicroLabel}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BackupRoot}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource InkBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="3"
                                        Content="Open"
                                        Command="{Binding OpenBackupFolderCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="12,5"
                                        MinWidth="76"
                                        MinHeight="32" />

                                <TextBlock Grid.Row="2" Text="Latest" Style="{StaticResource MicroLabel}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding LatestBackupSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Row="2"
                                        Grid.Column="3"
                                        Content="World folder"
                                        Command="{Binding OpenWorldFolderCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="12,5"
                                        MinWidth="112"
                                        MinHeight="32" />

                                <TextBlock Grid.Row="4" Text="Stored" Style="{StaticResource MicroLabel}" VerticalAlignment="Center" />
                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding BackupCount, StringFormat={}{0:N0} backups}" FontWeight="SemiBold" />
                                    <TextBlock Text="  •  " Foreground="{StaticResource SubtleBrush}" />
                                    <TextBlock Text="{Binding TotalBackupSize}" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Grid.Row="4"
                                           Grid.Column="3"
                                           Text="{Binding LatestBackupAge}"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" />

                                <Border Grid.Row="6"
                                        Grid.ColumnSpan="4"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource LineSoftBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="10,7">
                                    <TextBlock Text="{Binding SafetyHint}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Actions" Style="{StaticResource SectionTitle}" />

                            <UniformGrid Columns="2" Rows="2" Margin="0,14,0,0">
                                <Button Content="Create backup"
                                        Command="{Binding CreateBackupCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,8,8" />
                                <Button Content="Restore backup"
                                        Command="{Binding RestoreBackupCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="8,0,0,8" />
                                <Button Content="Check cloud"
                                        Command="{Binding CheckCloudCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,8,8,0" />
                                <Button Content="Upload current"
                                        Command="{Binding CheckCloudCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="8,8,0,0"
                                        IsEnabled="False" />
                            </UniformGrid>

                            <Border Margin="0,14,0,0"
                                    CornerRadius="8"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource LineSoftBrush}"
                                    BorderThickness="1"
                                    Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Cloud sync" FontWeight="SemiBold" />
                                        <TextBlock Text="Provider not configured" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="#2C2418"
                                            Padding="9,5"
                                            CornerRadius="7"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="TODO" Foreground="{StaticResource WarnBrush}" FontWeight="SemiBold" FontSize="12" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Activity" Style="{StaticResource SectionTitle}" />

                            <ScrollViewer Grid.Row="1"
                                          Margin="0,14,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Activity}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type domain:ActivityLogItem}">
                                            <Border BorderBrush="{StaticResource LineSoftBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="78" />
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                               Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Level}"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Level}" Value="Success">
                                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Message}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource InkBrush}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        <Border Grid.Row="2"
                Margin="28,12,28,18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                <ProgressBar Grid.Column="1"
                             Height="6"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource LineBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
